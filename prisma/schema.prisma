generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
}

enum PaymentMethod {
  UPI
  COD
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id          String     @id @default(cuid())
  name        String?
  email       String?    @unique
  mobile      String?    @unique
  role        UserRole   @default(CUSTOMER)
  addresses   Address[]
  orders      Order[]
  wishlists   Wishlist[]
  reviews     Review[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Address {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       AddressType @default(HOME)
  fullName    String
  phone       String
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  country     String      @default("India")
  orders      Order[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
}

model Product {
  id            String           @id @default(cuid())
  slug          String           @unique
  name          String
  description   String
  category      String
  featured      Boolean          @default(false)
  isNewArrival  Boolean          @default(false)
  isBestSeller  Boolean          @default(false)
  stockStatus   StockStatus      @default(IN_STOCK)
  variants      ProductVariant[]
  images        ProductImage[]
  orderItems    OrderItem[]
  wishlists     Wishlist[]
  reviews       Review[]
  restockAlerts RestockRequest[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([category])
  @@index([featured, isNewArrival, isBestSeller])
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String      @unique
  size          String
  color         String
  price         Decimal     @db.Decimal(10, 2)
  salePrice     Decimal?    @db.Decimal(10, 2)
  stockQuantity Int         @default(0)
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([productId])
  @@index([size, color])
}

model ProductImage {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl    String
  altText     String?
  displayRank Int       @default(0)

  @@index([productId])
}

model Order {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  addressId       String
  address         Address        @relation(fields: [addressId], references: [id], onDelete: Restrict)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus  @default(PENDING)
  status          OrderStatus    @default(PENDING)
  subtotal        Decimal        @db.Decimal(10, 2)
  deliveryCharge  Decimal        @db.Decimal(10, 2)
  totalAmount     Decimal        @db.Decimal(10, 2)
  paymentRef      String?
  adminNote       String?
  items           OrderItem[]
  paymentProof    PaymentProof?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([status, paymentStatus])
}

model OrderItem {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity      Int
  unitPrice     Decimal        @db.Decimal(10, 2)
  totalPrice    Decimal        @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

model PaymentProof {
  id             String        @id @default(cuid())
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  screenshotUrl  String
  referenceNo    String?
  verifiedAt     DateTime?
  createdAt      DateTime      @default(now())
}

model Wishlist {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Review {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating      Int
  title       String?
  comment     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productId])
  @@index([userId])
}

model RestockRequest {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String?
  mobile      String?
  createdAt   DateTime  @default(now())

  @@index([productId])
}
